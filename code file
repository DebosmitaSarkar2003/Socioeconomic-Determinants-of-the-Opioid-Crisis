#FIGURE 6: Random Forest Variable Importance for Predicting Opioid Mortality

if(nrow(complete_data) > 0) {
  #Prepare for random forest - REMOVE NA/NaN/Inf values
  rf_data <- complete_data %>%
    mutate(Year_Factor = as.factor(Year)) %>%
    select(State_Death_Rate, Poverty_Rate, Unemployment_Rate, 
           Pct_Uninsured, Median_Income, Pct_Bachelors_Plus, Year_Factor) %>%
    #Remove any rows with NA, NaN, or Inf values
    filter(
      is.finite(State_Death_Rate) &
        is.finite(Poverty_Rate) &
        is.finite(Unemployment_Rate) &
        is.finite(Pct_Uninsured) &
        is.finite(Median_Income) &
        is.finite(Pct_Bachelors_Plus)
    )
  
  cat("\n Random Forest Data Preparation \n")
  cat("Rows after removing NA/Inf:", nrow(rf_data), "\n")
  
  if(nrow(rf_data) < 50) {
    cat("WARNING: Too few complete observations for Random Forest\n")
  } else {
    # Train/test split
    set.seed(123)
    train_idx <- sample(1:nrow(rf_data), size=floor(0.7*nrow(rf_data)))
    rf_train <- rf_data[train_idx, ]
    
    cat("Training set:", nrow(rf_train), "observations\n")
    
    #Build model
    set.seed(123)
    rf_model <- randomForest(
      State_Death_Rate ~ .,
      data=rf_train,
      ntree=500,
      importance=TRUE,
      mtry=3,
      na.action=na.omit  
    )
    
    #Extract importance
    importance_df <- data.frame(
      Feature = rownames(importance(rf_model)),
      IncMSE = importance(rf_model)[, "%IncMSE"]
    ) %>%
      arrange(desc(IncMSE)) %>%
      #Use descriptive names instead of variable names
      mutate(Feature_Label = case_when(
        Feature == "Pct_Bachelors_Plus" ~ "Educational Attainment\n(Bachelor's Degree or Higher)",
        Feature == "Median_Income" ~ "Median Household Income",
        Feature == "Poverty_Rate" ~ "Poverty Rate",
        Feature == "Pct_Uninsured" ~ "Percentage Without\nHealth Insurance",
        Feature == "Unemployment_Rate" ~ "Unemployment Rate",
        Feature == "Year_Factor" ~ "Year (Temporal Trend)",
        TRUE ~ Feature
      ))
    
    p6 <- ggplot(importance_df, aes(x=reorder(Feature_Label, IncMSE), y=IncMSE)) +
      geom_bar(stat="identity", fill="steelblue", alpha=0.8) +
      coord_flip() +
      theme_minimal() +
      labs(
        x="",
        y="Importance (% Increase in Error When Variable Removed)"
      ) +
      theme(
        plot.title = element_text(size=14, face="bold", hjust=0.5),
        axis.text = element_text(size=11),
        axis.title = element_text(size=12)
      ) +
      labs(caption = "Figure 6. Random Forest Variable Importance for Predicting Opioid Mortality (2018-2023)\nHigher values indicate stronger predictive power. Educational attainment shows strongest association.\nModel trained on 70% of data using 500 decision trees.")
    
    ggsave("Figure_6_Variable_Importance.png", p6, width=10, height=7, dpi=300)
    cat("✓ Figure 6 saved\n")
  }
}

