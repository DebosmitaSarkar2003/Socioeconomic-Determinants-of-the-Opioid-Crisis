#READ CENSUS DATA

process_census_year_wide <- function(year) {
  filename_pattern <- paste0("ACSSPP1Y", year, ".S0201-2026-02-15")
  files <- list.files(".", pattern=glob2rx(paste0(filename_pattern, "*.csv")), 
                     full.names=FALSE)
  
  if(length(files) == 0) {
    stop(paste("No file found for year", year))
  }
  
  filename <- files[1]
  census_wide <- read.csv(filename, 
                          header=TRUE,
                          stringsAsFactors=FALSE,
                          fileEncoding="UTF-8-BOM",
                          check.names=FALSE)
  
  #Find variable rows
  income_row <- which(grepl("Median household income.*dollars", 
                           census_wide[[1]], ignore.case=TRUE))
  unemp_row <- which(grepl("Unemployment Rate", 
                          census_wide[[1]], ignore.case=TRUE))
  lesshs_row <- which(grepl("Less than high school diploma", 
                           census_wide[[1]], ignore.case=TRUE))
  bach_row <- which(grepl("Bachelor's degree or higher", 
                         census_wide[[1]], ignore.case=TRUE))
  uninsured_row <- which(grepl("No health insurance coverage", 
                               census_wide[[1]], ignore.case=TRUE))
  
  #FIXED: Find poverty row using multiple methods
  all_people_rows <- grep("All people", census_wide[[1]])
  poverty_row <- NULL
  for(i in all_people_rows) {
    if(!grepl("under|with|related|householder", census_wide[[1]][i], ignore.case=TRUE)) {
      poverty_row <- i
      break
    }
  }
  
  #Get state columns
  state_cols <- grep("!!.*!!Estimate$", names(census_wide), value=TRUE)
  state_names <- gsub("!!.*", "", state_cols)
  state_names <- gsub('"', '', state_names)
  
  #Create data frame
  census_data <- data.frame(
    State_Name = state_names,
    Year = as.numeric(year),
    stringsAsFactors = FALSE
  )
  
  #Extract values
  if(length(income_row) > 0) {
    census_data$Median_Income <- as.numeric(gsub(",|\\$", "", 
                                            unlist(census_wide[income_row[1], state_cols])))
  } else {
    census_data$Median_Income <- NA
  }
  
  if(length(unemp_row) > 0) {
    census_data$Unemployment_Rate <- as.numeric(gsub("%", "", 
                                            unlist(census_wide[unemp_row[1], state_cols])))
  } else {
    census_data$Unemployment_Rate <- NA
  }
  
  if(length(lesshs_row) > 0) {
    census_data$Pct_Less_HS <- as.numeric(gsub("%", "", 
                                            unlist(census_wide[lesshs_row[1], state_cols])))
  } else {
    census_data$Pct_Less_HS <- NA
  }
  
  if(length(bach_row) > 0) {
    census_data$Pct_Bachelors_Plus <- as.numeric(gsub("%", "", 
                                            unlist(census_wide[bach_row[1], state_cols])))
  } else {
    census_data$Pct_Bachelors_Plus <- NA
  }
  
  if(length(uninsured_row) > 0) {
    census_data$Pct_Uninsured <- as.numeric(gsub("%", "", 
                                            unlist(census_wide[uninsured_row[1], state_cols])))
  } else {
    census_data$Pct_Uninsured <- NA
  }
  
  if(length(poverty_row) > 0) {
    census_data$Poverty_Rate <- as.numeric(gsub("%", "", 
                                            unlist(census_wide[poverty_row[1], state_cols])))
  } else {
    census_data$Poverty_Rate <- NA
  }
  
  #Map to FIPS codes
  state_mapping <- c(
    "Alabama"="01", "Alaska"="02", "Arizona"="04", "Arkansas"="05",
    "California"="06", "Colorado"="08", "Connecticut"="09", "Delaware"="10",
    "District of Columbia"="11", "Florida"="12", "Georgia"="13", "Hawaii"="15",
    "Idaho"="16", "Illinois"="17", "Indiana"="18", "Iowa"="19", "Kansas"="20",
    "Kentucky"="21", "Louisiana"="22", "Maine"="23", "Maryland"="24",
    "Massachusetts"="25", "Michigan"="26", "Minnesota"="27", "Mississippi"="28",
    "Missouri"="29", "Montana"="30", "Nebraska"="31", "Nevada"="32",
    "New Hampshire"="33", "New Jersey"="34", "New Mexico"="35", "New York"="36",
    "North Carolina"="37", "North Dakota"="38", "Ohio"="39", "Oklahoma"="40",
    "Oregon"="41", "Pennsylvania"="42", "Rhode Island"="44", "South Carolina"="45",
    "South Dakota"="46", "Tennessee"="47", "Texas"="48", "Utah"="49",
    "Vermont"="50", "Virginia"="51", "Washington"="53", "West Virginia"="54",
    "Wisconsin"="55", "Wyoming"="56"
  )
  
  census_data$State_FIPS <- state_mapping[census_data$State_Name]
  return(census_data)
}

