#MERGE ALL DATASETS

#Convert data types
mortality_clean <- mortality_clean %>%
  mutate(
    State = as.character(State),
    Year = as.numeric(as.character(Year)),
    Deaths = as.numeric(as.character(Deaths)),
    Population = as.numeric(as.character(Population)),
    Crude_Rate = as.numeric(as.character(Crude_Rate))
  )

#Aggregate to state level
state_mortality <- mortality_clean %>%
  group_by(State, Year) %>%
  summarise(
    Total_Deaths = sum(Deaths, na.rm=TRUE),
    Avg_Crude_Rate = mean(Crude_Rate, na.rm=TRUE),
    Total_Population = sum(Population, na.rm=TRUE),
    N_Counties = n()
  ) %>%
  ungroup() %>%
  mutate(State_Death_Rate = (Total_Deaths / Total_Population) * 100000)

#Merge with prescriptions
